AIRTABLE_TABLE_SPEAKERS=
AIRTABLE_TABLE_AGENDA=
AIRTABLE_TABLE_FORMATS=
DATA_CACHING_OFF=false

SITE_SECRET=secret
API_KEY=key

NEXT_PUBLIC_VENUE_TZ=America/New_York
NEXT_PUBLIC_KEY_EXP=7776000000 # 3 months
NEXT_PUBLIC_BASE_URL=localhost:3000
NEXT_PUBLIC_EVENT_URL=
NEXT_PUBLIC_EVENT_NAME=Event
NEXT_PUBLIC_SITE_NAME="Speaker Portal"
NEXT_PUBLIC_EVENT_DESCRIPTION="Agenda and speaker information for this event."
NEXT_PUBLIC_EVENT_LOCATION="New York City"
NEXT_PUBLIC_ORGANIZER_NAME="AccelerateEvents Team"
NEXT_PUBLIC_SPEAKER_CONTACT_EMAIL=speakers@example.com
NEXT_PUBLIC_EVENT_REGISTRATION_PLATFORM=Luma
NEXT_PUBLIC_EVENT_COUPON_PARAM=coupon
NEXT_PUBLIC_SPEAKER_GUIDE_URL="https://docs.google.com/document/d/<document-id>"
NEXT_PUBLIC_HOME_SCHEDULE_ENABLED=true
NEXT_PUBLIC_SITE_LOGO_PATH=/accelerate-usa-logo.svg
NEXT_PUBLIC_SITE_LOGO_WIDTH=197
NEXT_PUBLIC_SITE_LOGO_HEIGHT=99
NEXT_PUBLIC_SOCIAL_IMAGE_PATH=/social-card.webp
EVENT_CALENDAR_NAME="Event Schedule"
EVENT_ORGANIZER_EMAIL=noreply@example.com
EVENT_GEO_LAT=
